# Same Upstash Redis the agent writes to (read-only here)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Telegram bot — token is used to verify the Login Widget hash.
# Must be the SAME bot the user talks to.
TELEGRAM_BOT_TOKEN=
# The bot's @username (without @), used to render the Login Widget.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Random secret used to sign the session cookie (any long random string).
SESSION_SECRET=
